generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Tabela de Denúncias do VoxCity
model Denuncia {
  id           String   @id @default(uuid())
  descricao    String
  latitude     Float?   
  longitude    Float?
  imagemUrl    String?  
  fotoUrl   String?
  endereco  String?
  apoios       Int      @default(0)
  iaSinalizada Boolean  @default(false) 
  criadoEm     DateTime @default(now())
}